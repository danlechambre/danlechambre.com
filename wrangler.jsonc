{
  "main": "@astrojs/cloudflare/entrypoints/server",
  "name": "danlechambre-web",
  "compatibility_date": "2026-03-06",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
  },
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "pattern": "danlechambre.com",
      "custom_domain": true,
    },
  ],
}
